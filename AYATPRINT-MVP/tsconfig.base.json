{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,

    /* Path Aliases - Harmonized for both @ayatstudio/* and @ayat/* */
    "baseUrl": ".",
    "paths": {
      "@ayatstudio/types": ["packages/types/src/index.ts"],
      "@ayatstudio/ui": ["packages/ui/src/index.ts"],
      "@ayatstudio/studio-core": ["packages/studio-core/src/index.ts"],
      "@ayatstudio/mockup-engine": ["packages/mockup-engine/src/index.tsx"],
      "@ayatstudio/db": ["packages/db/src/index.ts"],
      "@ayat/types": ["packages/types/src/index.ts"],
      "@ayat/ui": ["packages/ui/src/index.ts"],
      "@ayat/studio-core": ["packages/studio-core/src/index.ts"],
      "@ayat/mockup-engine": ["packages/mockup-engine/src/index.tsx"],
      "@ayat/db": ["packages/db/src/index.ts"]
    }
  }
}
