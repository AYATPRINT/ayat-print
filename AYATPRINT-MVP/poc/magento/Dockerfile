# Magento (Adobe Commerce) POC Dockerfile Stub
# Magento requires a highly complex environment (ElasticSearch, RabbitMQ, Varnish). 
# For this POC, we use a community image stub to represent the Magento node in the architecture.
FROM bitnami/magento:latest

# Note: In a real environment, this requires significant volume mounts and dependent services.
EXPOSE 8080
EXPOSE 8443
